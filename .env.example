# =====================================================================
# CSO Capstone — environment variables
#
# Copy this file to `.env` and fill in your keys. .env is gitignored.
# Pick ONE provider; the system uses that provider for all agents.
# =====================================================================

# ────────── 1. Pick your LLM provider ─────────────────────────────────
# One of: openai | azure_openai | anthropic | google | groq | ollama | mock
# (Leave blank to auto-detect: it'll pick the first provider with keys set.)
LLM_PROVIDER=anthropic

# Force MOCK mode (deterministic, no API calls). Useful for tests / CI.
# LLM_MODE=mock

# ────────── 2. Set the matching API key ───────────────────────────────

# ── Anthropic (Claude) — console.anthropic.com ────────────────────────
ANTHROPIC_API_KEY=

# ── Azure OpenAI — portal.azure.com ──────────────────────────────────
# Required for LLM_PROVIDER=azure_openai:
#   AZURE_OPENAI_API_KEY   — found under "Keys and Endpoint" in your
#                            Azure OpenAI resource in the Azure portal.
#   AZURE_OPENAI_ENDPOINT  — the resource URL, e.g.
#                            https://<your-resource-name>.openai.azure.com/
#   AZURE_OPENAI_API_VERSION — optional, defaults to 2024-02-01
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_VERSION=2024-02-01

# ── OpenAI — platform.openai.com ─────────────────────────────────────
OPENAI_API_KEY=

# ── Google Gemini — aistudio.google.com/apikey ───────────────────────
GEMINI_API_KEY=

# ── Groq (runs Llama 3.3 70B fast and cheap) — console.groq.com ──────
GROQ_API_KEY=

# ── Ollama (local Llama, no key) — install from ollama.com, then: ─────
#   ollama pull llama3.1:8b
# OLLAMA_BASE_URL=http://localhost:11434   # default, only set if non-default

# ────────── 3. Per-tier model overrides (optional) ────────────────────
# Each agent uses one of three tiers: fast | smart | judge
# Defaults per provider are in llm_clients.py / TIER_DEFAULTS.
#
# For Azure OpenAI these MUST match your actual deployment names
# (the name you gave the deployment in the Azure portal, not the
# underlying OpenAI model name):
# OVERRIDE_FAST_MODEL=my-gpt4o-mini-deployment
# OVERRIDE_SMART_MODEL=my-gpt4o-deployment
# OVERRIDE_JUDGE_MODEL=my-gpt4o-mini-deployment
#
# For Anthropic / OpenAI / Gemini override with the model ID directly:
# OVERRIDE_FAST_MODEL=claude-haiku-4-5-20251001
# OVERRIDE_SMART_MODEL=claude-sonnet-4-6
# OVERRIDE_JUDGE_MODEL=claude-haiku-4-5-20251001

# ────────── 4. LangSmith — tracing + evaluation ───────────────────────
# Sign up at https://smith.langchain.com (free tier: 5k traces/month)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=cso-capstone
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com   # default

# ────────── 5. Kaggle (only for retraining the fraud model) ───────────
# kagglehub reads ~/.kaggle/kaggle.json automatically. No env var needed.
# Get your token at https://www.kaggle.com/settings/account
