# =====================================================================
# CSO Capstone — environment variables
#
# Copy this file to `.env` and fill in your keys. .env is gitignored.
# Pick ONE provider; the system uses that provider for all agents.
# =====================================================================

# ────────── 1. Pick your LLM provider ─────────────────────────────────
# One of: openai | anthropic | google | groq | ollama | mock
# (Leave blank to auto-detect: it'll pick the first provider with a key set.)
LLM_PROVIDER=google

# Force MOCK mode (deterministic, no API calls). Useful for tests / CI.
# LLM_MODE=mock

# ────────── 2. Set the matching API key ───────────────────────────────

# OpenAI — sign up at platform.openai.com
OPENAI_API_KEY=

# Anthropic — sign up at console.anthropic.com
ANTHROPIC_API_KEY=

# Google Gemini — sign up at aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq (runs Llama 3.3 70B fast and cheap) — sign up at console.groq.com
GROQ_API_KEY=

# Ollama (local Llama, no key) — install from ollama.com, then:
#   ollama pull llama3.1:8b
# OLLAMA_BASE_URL=http://localhost:11434   # default, only set if non-default

# ────────── 3. Per-tier model overrides (optional) ────────────────────
# Each agent uses one of three tiers: fast | smart | judge
# Defaults per provider are in llm_clients.py / TIER_DEFAULTS.
# Override any tier:
# OVERRIDE_FAST_MODEL=gpt-4o-mini
# OVERRIDE_SMART_MODEL=claude-sonnet-4-5
# OVERRIDE_JUDGE_MODEL=gemini-2.5-flash

# ────────── 4. LangSmith — tracing + evaluation ───────────────────────
# Sign up at https://smith.langchain.com (free tier: 5k traces/month)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=cso-capstone
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com   # default

# ────────── 5. Kaggle (only for retraining the fraud model) ───────────
# kagglehub reads ~/.kaggle/kaggle.json automatically. No env var needed.
# Get your token at https://www.kaggle.com/settings/account
