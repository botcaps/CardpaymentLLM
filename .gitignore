# ────────────────────────────────────────────────────────────────────
# CSO Capstone — .gitignore
#
# Principle: the repo contains code + small config + small artifacts.
# It does NOT contain datasets, vector stores, trained model binaries,
# or anything that can be regenerated by re-running the pipeline.
# ────────────────────────────────────────────────────────────────────

# ── Python ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
parts/
sdist/
wheels/
share/python-wheels/
MANIFEST

# ── Virtual environments ────────────────────────────────────────────
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# ── Editor / OS ─────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Secrets ─────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
.kaggle/

# ── Logs ────────────────────────────────────────────────────────────
*.log
logs/

# ── Test / coverage ─────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# ────────────────────────────────────────────────────────────────────
# Project-specific — datasets, vector stores, model binaries
# ────────────────────────────────────────────────────────────────────

# ── Kaggle data (fetched at runtime via kagglehub) ──────────────────
data/kaggle_cache/

# ── Vector store (rebuilt from rag/ingest.py on first run) ──────────
rag/chroma_db/
rag/.chroma/
rag/corpus_cache/

# ── Trained ML models (rebuild via `python ml/training/train_fraud.py`)
# Tip: keep ml/fraud_model.pkl gitignored if it's >5MB; if you want
# graders to skip retraining, comment out the next line and commit the .pkl
ml/*.pkl
ml/*.joblib

# ── Evaluation outputs (regenerated by python evaluation/run_evals.py)
evaluation/results/*.json
evaluation/results/*.png
evaluation/results/*.html
evaluation/results/cache/

# ── LangSmith / LangChain caches ────────────────────────────────────
.langchain.db
.langgraph_api/

# ── Streamlit cache ─────────────────────────────────────────────────
.streamlit/secrets.toml

# ── Notebook checkpoints ────────────────────────────────────────────
.ipynb_checkpoints/
